services:
  element-web:
    image: "{{ element_image }}:{{ element_version }}"
    container_name: "{{ element_container_name }}"
    restart: unless-stopped
    ports:
      - "{{ docker_bind_address }}:{{ element_http_port }}:80"
    volumes:
      - "{{ element_base_dir }}/config.json:/usr/share/nginx/html/config.json:ro"
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost/config.json"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
      